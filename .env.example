# WhatsApp number (international format, no plus or spaces)
VITE_WA_NUMBER=919961980960

# Google Analytics 4 (optional)
VITE_GA_ID=

# ---------------------------------------------------------------------------
# Worldwide payments. Configure any or all providers. Each is optional —
# whichever you fill in will appear on the Build Your Resume checkout step.
# Any unconfigured provider is hidden, and a WhatsApp order fallback always
# remains available.
# ---------------------------------------------------------------------------

# Default checkout currency: INR or USD
VITE_DEFAULT_CURRENCY=INR

# Stripe — paste a Payment Link per plan (Dashboard > Payment Links)
VITE_STRIPE_LINK_STANDARD=
VITE_STRIPE_LINK_PREMIUM=
VITE_STRIPE_LINK_EXECUTIVE=

# PayPal — your live/sandbox client ID (renders PayPal Buttons)
VITE_PAYPAL_CLIENT_ID=

# Razorpay — public key id (Cards, UPI, NetBanking, Wallets)
VITE_RAZORPAY_KEY_ID=
